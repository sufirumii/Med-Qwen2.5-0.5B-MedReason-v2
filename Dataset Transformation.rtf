\f0\fs24 \cf0 import json\
from datasets import load_dataset\
from tqdm import tqdm\
\
# 1. Load the new GLM-4.5-Air dataset\
# This dataset contains ~225,179 rows\
print("Loading GLM-4.5-Air dataset...")\
dataset = load_dataset("OpenMed/Medical-Reasoning-SFT-GLM_4.5_Air", split="train")\
\
def transform_row(row):\
    """\
    Strips reasoning_content and retains only the 'role' and 'content' \
    fields for Qwen Instruct compatibility.\
    """\
    new_messages = []\
    for msg in row['messages']:\
        new_messages.append(\{\
            "role": msg['role'],\
            "content": msg['content']\
        \})\
    return \{"messages": new_messages\}\
\
# 2. Path for saving\
output_path = "/kaggle/working/medical_glm_finetune.jsonl"\
print(f"Transforming and saving to \{output_path\}...")\
\
# 3. Process and write to JSONL\
# Using tqdm to monitor progress given the larger size (225k rows)\
with open(output_path, "w", encoding="utf-8") as f:\
    for row in tqdm(dataset, desc="Processing Rows"):\
        formatted_row = transform_row(row)\
        # ensure_ascii=False ensures medical terms/special characters are preserved\
        f.write(json.dumps(formatted_row, ensure_ascii=False) + "\\n")\
\
print(f"\\nSuccess! \{len(dataset)\} samples saved to \{output_path\}.")\
print("The dataset is now ready for Qwen fine-tuning.")}